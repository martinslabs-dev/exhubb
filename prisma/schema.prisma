// Exhubb — Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  phone         String?   @unique
  image         String?
  password      String?

  // Progressive roles
  isBuyer      Boolean @default(true)
  isSeller     Boolean @default(false)
  isFreelancer Boolean @default(false)

  // Security
  isLocked    Boolean   @default(false)
  lockedUntil DateTime?

  // Auth.js relations
  accounts  Account[]
  sessions  Session[]
  otpTokens OtpToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── OTP tokens (email verification + password reset) ─────────
model OtpToken {
  id        String   @id @default(cuid())
  userId    String
  email     String
  code      String   // bcrypt-hashed 6-digit code
  type      OtpType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type])
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ─── Auth.js required models ──────────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

